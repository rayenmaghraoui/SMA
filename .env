# ============================================================
# AI Business Consultant — PFE
# Variables d'environnement
# NE PAS COMMITER CE FICHIER (ajouter .env dans .gitignore)
# ============================================================

# --- LLM (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# --- Embeddings — sentence-T5-base (recommandé par l'encadrant) ---
EMBEDDING_MODEL=sentence-transformers/sentence-t5-base

# --- Chemins ---
DATA_DIR=./data
DOCUMENTS_DIR=./documents
CHROMA_DB_PATH=./backend/rag/chroma_db
UPLOADS_DIR=./data/uploads

# --- RAG — stratégie d'indexation hybride ---
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:5173

# --- Environnement ---
DEBUG=true
